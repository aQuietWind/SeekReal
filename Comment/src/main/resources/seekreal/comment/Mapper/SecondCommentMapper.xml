<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="seekreal.comment.Mapper.SecondCommentMapper">
    <!--    新增用户-->
    <insert id="insertSecondComment">
        insert into Second_Comment (
        second_comment_id
        ,user_id
        ,first_comment_id
        ,text
        ,respond_username
        ) values(
        #{secondCommentId}
        ,#{userId}
        ,#{firstCommentId}
        ,#{text}
        ,#{respondUsername}
        )
    </insert>


    <!--    删除某篇存在的提问-->
    <update id="deleteQuestion">
        update Question set is_exist=0 where user_id=#{userId} and question_id=#{questionId} and is_exist=1
    </update>

    <!--    获取提问的详细内容-->
    <select id="getQuestionById" resultType="pojo.KnowAsk.Question">
        select question_id
        ,user_id
        ,question_title
        ,question_description
        ,image_adder_list
        ,writing_amount
        ,like_amount
        ,collect_amount
        ,is_exist
        ,create_time
        from Question where question_id=#{questionId} and is_exist=1
    </select>




</mapper>